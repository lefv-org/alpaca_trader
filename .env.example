# Alpaca API credentials
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
# ORDER_NOTIONAL=10
# Path to gain accumulator principal snapshot file (must be writable)
# GAIN_ACCUMULATOR_PATH=priv/gain_accumulator.json
# PORTFOLIO_RESERVE_PCT=0.25
# ALLOW_SHORT_SELLING=false

# LLM Opinion Gate (optional — trades execute at 0.5 conviction if not set)
# Pin to one provider or omit for automatic failover: mlx → ollama → anthropic
# LLM_PROVIDER=mlx

# Failover chain: MLX (local) → Ollama (remote) → Anthropic (cloud)

# MLX local server (default, no key required)
# LLM_BASE_URL=http://localhost:8081
# LLM_MODEL=mlx-community/Ministral-3-8B-Instruct-2512-4bit

# Ollama remote fallback
# OLLAMA_BASE_URL=https://ollama.lefv.info
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_API_KEY=

# Anthropic cloud fallback (or set ANTHROPIC_BASE_URL to proxy through Claude Pro Max)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-haiku-4-5-20250501

# Polymarket signal feed (public API, no key required)
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_POLL_INTERVAL_S=30
# POLYMARKET_SHIFT_THRESHOLD=0.10
# POLYMARKET_MIN_VOLUME=5000
