# Alpaca API credentials
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
# Trade size as fraction of equity (0.001 = 0.1% per trade)
# ORDER_NOTIONAL_PCT=0.001
# Round-trip fee rate — gain gate threshold = equity * notional_pct * fee_rate
# TRADE_FEE_RATE=0.003
# Path to gain accumulator principal snapshot file (must be writable)
# GAIN_ACCUMULATOR_PATH=priv/gain_accumulator.json
# PORTFOLIO_RESERVE_PCT=0.25
# ALLOW_SHORT_SELLING=false

# LLM Opinion Gate (optional — trades execute at 0.5 conviction if no providers enabled)
# Enable/disable each provider independently. Enabled providers are tried in order: MLX → Ollama → Anthropic
LLM_USE_MLX=false
LLM_USE_OLLAMA=false
LLM_USE_ANTHROPIC=false

# MLX local server (no key required)
# LLM_BASE_URL=http://localhost:8080
# LLM_MODEL=mlx-community/Ministral-3-8B-Instruct-2512-4bit

# Ollama remote
# OLLAMA_BASE_URL=https://ollama.lefv.info
# OLLAMA_MODEL=phi4-mini:4k
# OLLAMA_API_KEY=
# OLLAMA_TIMEOUT_MS=30000

# Cerebras free cloud
# LLM_USE_CEREBRAS=false
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_API_KEY=

# OpenRouter free cloud
# LLM_USE_OPENROUTER=false
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_API_KEY=

# Anthropic cloud
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Polymarket signal feed (public API, no key required)
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_POLL_INTERVAL_S=30
# POLYMARKET_SHIFT_THRESHOLD=0.10
# POLYMARKET_MIN_VOLUME=5000
